<odoo>
    <record id="view_sale_order_form_inherit_price_total" model="ir.ui.view">
    <field name="name">sale.order.form.inherit.price.total</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">

        <!-- Sale order lines tree -->
        <xpath expr="//field[@name='order_line']/list/field[@name='price_subtotal']" position="after">
            <field name="price_total"/>
        </xpath>

    </field>
</record>
<record id="view_move_form_inherit_price_total" model="ir.ui.view">
    <field name="name">account.move.form.inherit.price.total</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">

        <!-- Invoice lines tree -->
        <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='price_subtotal']" position="after">
            <field name="price_total"/>
        </xpath>

    </field>
</record>

</odoo>